# Copie ce fichier en .env et remplis les valeurs

# Clé secrète JWT — génère une vraie clé avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=remplace_par_une_vraie_cle_aleatoire_longue

# Taille max des fichiers en MB (défaut: 500)
MAX_FILE_MB=500

# Port du serveur (défaut: 3000)
PORT=3000
